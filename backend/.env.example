# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/warehouse_hq?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=warehouse-inventory-hq-images
S3_PRESIGNED_URL_EXPIRES=3600

# eBay API
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_REDIRECT_URI=https://your-backend.onrender.com/api/ebay/callback
EBAY_SANDBOX=true

# Sentry (Error Monitoring)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Encryption
ENCRYPTION_KEY=32_char_hex_key_for_sensitive_data

# Admin Bootstrap (used on first run to create initial admin)
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Immediately_2024!
BOOTSTRAP_ADMIN_EMPLOYEE_ID=ADMIN001
